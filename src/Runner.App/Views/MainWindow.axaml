<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Runner.App.ViewModels"
        xmlns:i="https://github.com/projektanker/icons.avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="420"
        d:DesignHeight="170"
        x:Class="Runner.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Runner"
        Width="420"
        Height="170"
        MinWidth="{Binding WindowMinWidth}"
        MinHeight="{Binding WindowMinHeight}"
        CanResize="True"
        WindowDecorations="BorderOnly"
        Topmost="{Binding AlwaysOnTop}"
        Opacity="{Binding RunnerOpacity}">

    <Grid RowDefinitions="*,Auto">
        <Grid Grid.Row="0"
              Margin="4">
            <StackPanel IsVisible="{Binding HasNoRunners}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <TextBlock Text="No runners configured."
                           Foreground="#667085"
                           FontSize="13"
                           HorizontalAlignment="Center" />
                <Button Command="{Binding AddRunnerCommand}"
                        HorizontalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6">
                        <i:Icon Value="fa-solid fa-plus"
                                FontSize="11"
                                VerticalAlignment="Center" />
                        <TextBlock Text="Add" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <ListBox ItemsSource="{Binding Runners}"
                     SelectedItem="{Binding SelectedRunner}"
                     IsVisible="{Binding HasRunners}">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="vm:RunnerViewModel"
                                  x:CompileBindings="False">
                        <Border Padding="4,2"
                                MinHeight="34"
                                Background="Transparent">
                            <Grid RowDefinitions="Auto,Auto"
                                  RowSpacing="3">
                                <Grid Grid.Row="0"
                                      ColumnDefinitions="*,Auto,Auto,Auto"
                                      ColumnSpacing="6"
                                      VerticalAlignment="Center">
                                    <Grid Grid.Column="0"
                                          RowDefinitions="Auto,Auto"
                                          RowSpacing="1"
                                          VerticalAlignment="Center">
                                        <TextBlock Grid.Row="0"
                                                   Text="{Binding Header}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding WorkingDirectory}"
                                                   FontSize="11"
                                                   Opacity="0.72"
                                                   TextTrimming="CharacterEllipsis"
                                                   IsVisible="{Binding DataContext.ShowProjectPaths, RelativeSource={RelativeSource AncestorType=Window}}" />
                                    </Grid>

                                    <Border Grid.Column="1"
                                            Padding="6,2"
                                            CornerRadius="4"
                                            Background="{Binding DashboardStatusBackground}"
                                            BorderBrush="{Binding DashboardStatusBorderBrush}"
                                            BorderThickness="1"
                                            MaxWidth="120"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            IsVisible="{Binding IsDashboardStatusVisible}"
                                            ToolTip.Tip="{Binding DashboardStatusToolTip}">
                                        <Grid ColumnDefinitions="Auto,*"
                                              ColumnSpacing="5">
                                            <i:Icon Grid.Column="0"
                                                    Value="{Binding DashboardStatusIconValue}"
                                                    Animation="{Binding DashboardStatusIconAnimation}"
                                                    Foreground="{Binding DashboardStatusForeground}"
                                                    FontSize="9"
                                                    VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding DashboardStatusText}"
                                                       Foreground="{Binding DashboardStatusForeground}"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </Border>

                                    <Button Grid.Column="2"
                                            Width="30"
                                            Height="30"
                                            Padding="0"
                                            Command="{Binding DataContext.RunRunnerCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            ToolTip.Tip="{Binding PrimaryRunToolTip}">
                                        <i:Icon Value="{Binding PrimaryRunIconValue}"
                                                Animation="{Binding PrimaryRunIconAnimation}"
                                                FontSize="12"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                    </Button>
                                    <Button Grid.Column="3"
                                            Width="30"
                                            Height="30"
                                            Padding="0"
                                            Command="{Binding ShowFailureDetailsCommand}"
                                            IsVisible="{Binding HasFailureDetails}"
                                            ToolTip.Tip="Failure details">
                                        <i:Icon Value="fa-solid fa-triangle-exclamation"
                                                FontSize="12"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center" />
                                    </Button>
                                </Grid>

                                <Border Grid.Row="1"
                                        IsVisible="{Binding IsFailureDetailsVisible}"
                                        Margin="0,4,0,0"
                                        Padding="8"
                                        CornerRadius="5"
                                        Background="#2A1111"
                                        BorderBrush="#EF4444"
                                        BorderThickness="1">
                                    <Grid RowDefinitions="Auto,Auto">
                                        <Grid Grid.Row="0"
                                              ColumnDefinitions="*,Auto"
                                              Margin="0,0,0,6">
                                            <TextBlock Grid.Column="0"
                                                       Text="Failure details"
                                                       FontSize="12"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FEF2F2"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="1"
                                                    Width="26"
                                                    Height="26"
                                                    Padding="0"
                                                    Command="{Binding HideFailureDetailsCommand}"
                                                    ToolTip.Tip="Hide failure details">
                                                <i:Icon Value="fa-solid fa-xmark"
                                                        FontSize="11"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center" />
                                            </Button>
                                        </Grid>

                                        <TextBox Grid.Row="1"
                                                 Text="{Binding FailureDetailsText}"
                                                 IsReadOnly="True"
                                                 AcceptsReturn="True"
                                                 Height="92"
                                                 FontFamily="Consolas, Menlo, monospace"
                                                 FontSize="11"
                                                 TextWrapping="NoWrap"
                                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                 ScrollViewer.HorizontalScrollBarVisibility="Auto" />
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto"
              Margin="4,0,4,4"
              ColumnSpacing="6">
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusMessage}"
                       Foreground="#475467"
                       FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       VerticalAlignment="Center" />
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="4"
                        VerticalAlignment="Center">
                <Button Width="20"
                        Height="20"
                        Padding="0"
                        Background="{Binding AlwaysOnTopButtonBackground}"
                        Command="{Binding ToggleAlwaysOnTopCommand}"
                        ToolTip.Tip="{Binding AlwaysOnTopToolTip}">
                    <i:Icon Value="fa-solid fa-thumbtack"
                            Foreground="{Binding AlwaysOnTopIconForeground}"
                            FontSize="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                </Button>
                <Button Width="20"
                        Height="20"
                        Padding="0"
                        Click="OnSettingsButtonClick"
                        ToolTip.Tip="Settings">
                    <i:Icon Value="fa-solid fa-gear"
                            FontSize="10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
